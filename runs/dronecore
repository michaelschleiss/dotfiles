#!/usr/bin/env bash
set -euo pipefail
LOG_PREFIX="[dronecore]"
source "$(dirname "$0")/lib"

# Dronecore (Jetson) SSH setup - works on macOS and Linux

read -r -d '' DRONECORE_FUNC_MAC <<'EOF' || true
dronecore() {
  local inet_if="${1:-$(route get default 2>/dev/null | awk '/interface:/ {print $2}')}"
  local drone_if pf_rules pf_anchor="com.apple/dronecore"

  if [[ -z "$inet_if" ]]; then
    echo "[dronecore] ERROR: Could not detect internet interface. Pass it as argument: dronecore en0"
    return 1
  fi

  drone_if="$(ifconfig | awk '
    /^[^ \t]/ { iface=$1; sub(/:$/, "", iface) }
    /inet 192\.168\.55\./ { print iface; exit }
  ')"
  if [[ -z "$drone_if" ]]; then
    echo "[dronecore] ERROR: No interface on 192.168.55.x - is dronecore connected?"
    return 1
  fi

  echo "[dronecore] uplink=$inet_if drone_if=$drone_if"

  if ! sudo -v; then
    echo "[dronecore] ERROR: sudo authentication failed"
    return 1
  fi

  sudo sysctl -w net.inet.ip.forwarding=1 >/dev/null

  pf_rules="$(mktemp -t dronecore.pf.XXXXXX)"
  command cat >"$pf_rules" <<PF
nat on $inet_if from $drone_if:network to any -> ($inet_if)
pass from $drone_if:network to any keep state
pass from any to $drone_if:network keep state
PF

  sudo pfctl -E >/dev/null 2>&1 || true
  sudo pfctl -a "$pf_anchor" -f "$pf_rules" >/dev/null
  rm -f "$pf_rules"
  echo "[dronecore] NAT enabled on $inet_if for $drone_if"

  if command -v sshpass >/dev/null 2>&1; then
    sshpass -p dronecore ssh \
      -o StrictHostKeyChecking=no \
      -o UserKnownHostsFile=/dev/null \
      -o LogLevel=ERROR \
      dcs_user@192.168.55.1
  elif command -v expect >/dev/null 2>&1; then
    expect -c '
set timeout -1
spawn ssh -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -o LogLevel=ERROR dcs_user@192.168.55.1
expect {
  -re "(?i)are you sure you want to continue connecting" { send "yes\r"; exp_continue }
  -re "(?i)password:" { send "dronecore\r" }
  eof { exit 1 }
}
interact
'
  else
    echo "[dronecore] ERROR: Install sshpass or expect"
    return 1
  fi
}
EOF

read -r -d '' DRONECORE_FUNC_LINUX <<'EOF' || true
dronecore() {
  local drone_if

  drone_if="$(ip -o -4 addr show | awk '$4 ~ /^192\.168\.55\./ { print $2; exit }')"
  if [[ -z "$drone_if" ]]; then
    echo "[dronecore] ERROR: No interface on 192.168.55.x - is dronecore connected?"
    return 1
  fi

  echo "[dronecore] drone_if=$drone_if"

  if ! sudo -v; then
    echo "[dronecore] ERROR: sudo authentication failed"
    return 1
  fi

  sudo sysctl -w net.ipv4.ip_forward=1 >/dev/null
  sudo iptables -t nat -C POSTROUTING -s 192.168.55.0/24 -j MASQUERADE 2>/dev/null || \
    sudo iptables -t nat -A POSTROUTING -s 192.168.55.0/24 -j MASQUERADE
  sudo iptables -C FORWARD -s 192.168.55.0/24 -j ACCEPT 2>/dev/null || \
    sudo iptables -I FORWARD 1 -s 192.168.55.0/24 -j ACCEPT
  sudo iptables -C FORWARD -d 192.168.55.0/24 -j ACCEPT 2>/dev/null || \
    sudo iptables -I FORWARD 1 -d 192.168.55.0/24 -j ACCEPT

  if command -v sshpass >/dev/null 2>&1; then
    sshpass -p dronecore ssh \
      -o StrictHostKeyChecking=no \
      -o UserKnownHostsFile=/dev/null \
      -o LogLevel=ERROR \
      dcs_user@192.168.55.1
  elif command -v expect >/dev/null 2>&1; then
    expect -c '
set timeout -1
spawn ssh -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -o LogLevel=ERROR dcs_user@192.168.55.1
expect {
  -re "(?i)are you sure you want to continue connecting" { send "yes\r"; exp_continue }
  -re "(?i)password:" { send "dronecore\r" }
  eof { exit 1 }
}
interact
'
  else
    echo "[dronecore] ERROR: Install sshpass or expect"
    return 1
  fi
}
EOF

# Validate SSH helper availability up front so the installed function is usable.
if command -v sshpass &>/dev/null; then
  log "Using sshpass for password SSH"
elif command -v expect &>/dev/null; then
  log "Using expect fallback for password SSH"
else
  log "ERROR: Neither sshpass nor expect is available"
  exit 1
fi

# Determine profile file
if [[ "${SHELL:-}" == */zsh ]] || [[ -f "$HOME/.zshrc" ]]; then
  PROFILE="$HOME/.zshrc"
elif [[ -f "$HOME/.zprofile" ]]; then
  PROFILE="$HOME/.zprofile"
elif [[ -f "$HOME/.bash_profile" ]]; then
  PROFILE="$HOME/.bash_profile"
else
  PROFILE="$HOME/.bashrc"
fi

touch "$PROFILE"
_sed_i "/^alias dronecore=/d" "$PROFILE" 2>/dev/null || true

if [[ "$os_name" == "Darwin" ]]; then
  add_block_to_file "$PROFILE" "dronecore" "$DRONECORE_FUNC_MAC"
else
  add_block_to_file "$PROFILE" "dronecore" "$DRONECORE_FUNC_LINUX"
fi

log "Done! Run 'source $PROFILE' or restart shell, then use: dronecore"
