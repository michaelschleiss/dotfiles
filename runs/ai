#!/usr/bin/env bash
set -euo pipefail
LOG_PREFIX="[ai]"
source "$(dirname "$0")/_lib"

export PATH="${HOME}/.local/bin:${PATH}"

ensure_cmd() {
  local cmd="$1"
  local pkg="${2:-}"

  if have "$cmd"; then
    return 0
  fi

  if [[ -z "${pkg}" ]]; then
    echo "Missing required command: ${cmd}" >&2
    return 1
  fi

  if [[ "$os_name" == "Darwin" ]] && have brew; then
    log "Installing ${pkg} (Homebrew)"
    brew install "$pkg"
    return 0
  fi

  if [[ "$os_name" == "Linux" ]] && have apt-get; then
    log "Installing ${pkg} (apt)"
    sudo apt-get update
    sudo apt-get install -y "$pkg"
    return 0
  fi

  echo "Missing required command: ${cmd} (and no supported package manager found)" >&2
  return 1
}

install_ripgrep() {
  if have rg; then
    return 0
  fi

  if [[ "$os_name" == "Darwin" ]] && have brew; then
    log "Installing ripgrep (Homebrew)"
    brew install ripgrep
    return 0
  fi

  if [[ "$os_name" == "Linux" ]] && have apt-get; then
    log "Installing ripgrep (apt)"
    sudo apt-get update
    sudo apt-get install -y ripgrep
    return 0
  fi

  echo "ripgrep (rg) is required for codex. Install it and re-run this script." >&2
  return 1
}

codex_target() {
  case "${os_name}/${arch_name}" in
    Darwin/arm64 | Darwin/aarch64) echo "aarch64-apple-darwin" ;;
    Darwin/x86_64 | Darwin/amd64) echo "x86_64-apple-darwin" ;;
    Linux/x86_64 | Linux/amd64) echo "x86_64-unknown-linux-musl" ;;
    Linux/arm64 | Linux/aarch64) echo "aarch64-unknown-linux-musl" ;;
    *) return 1 ;;
  esac
}

install_codex_from_github() {
  local target
  target="$(codex_target)" || {
    echo "Unsupported platform for codex: ${os_name} ${arch_name}" >&2
    return 1
  }

  ensure_cmd curl curl
  ensure_cmd tar tar

  local asset="codex-${target}.tar.gz"
  local url="https://github.com/openai/codex/releases/latest/download/${asset}"
  local tmpdir
  tmpdir="$(mktemp -d)"

  local install_dir="${HOME}/.local/bin"
  mkdir -p "${install_dir}"

  local installed_version=""
  if [[ -x "${install_dir}/codex" ]]; then
    installed_version="$("${install_dir}/codex" --version 2>/dev/null | grep -Eo '[0-9]+\\.[0-9]+\\.[0-9]+' | head -n 1 || true)"
  fi

  local latest_version=""
  local release_json=""
  release_json="$(curl -fsSL "https://api.github.com/repos/openai/codex/releases/latest" 2>/dev/null || true)"
  latest_version="$(printf '%s' "${release_json}" | grep -m1 '"tag_name"' | grep -Eo '[0-9]+\\.[0-9]+\\.[0-9]+' | head -n 1 || true)"

  if [[ -n "${installed_version}" && -n "${latest_version}" && "${installed_version}" == "${latest_version}" ]]; then
    log "codex already up to date: ${installed_version}"
    rm -rf "${tmpdir}"
    return 0
  fi

  if [[ -n "${installed_version}" ]]; then
    if [[ -n "${latest_version}" ]]; then
      log "Updating codex: ${installed_version} -> ${latest_version}"
    else
      log "Updating codex (current: ${installed_version})"
    fi
  else
    log "Installing codex"
  fi

  log "Downloading codex (${target})"
  curl -fsSL "${url}" -o "${tmpdir}/${asset}"

  tar -xzf "${tmpdir}/${asset}" -C "${tmpdir}"

  local extracted_bin="${tmpdir}/codex-${target}"
  if [[ ! -f "${extracted_bin}" ]]; then
    rm -rf "${tmpdir}"
    echo "Expected ${extracted_bin} after extracting ${asset}" >&2
    return 1
  fi

  install -m 0755 "${extracted_bin}" "${install_dir}/codex"
  rm -rf "${tmpdir}"
  log "Installed codex to ${install_dir}/codex ($(\"${install_dir}/codex\" --version 2>/dev/null || echo ok))"
}

install_codex() {
  install_ripgrep

  if [[ "$os_name" == "Darwin" ]] && have brew; then
    export HOMEBREW_NO_AUTO_UPDATE=1
    export HOMEBREW_NO_ENV_HINTS=1

    if ! brew list --cask codex >/dev/null 2>&1; then
      log "Installing codex (Homebrew cask)"
      brew install --cask codex
      return 0
    fi

    local installed latest
    installed="$(brew list --cask --versions codex 2>/dev/null | awk '{print $2}')"
    latest="$(brew info --cask --json=v2 codex 2>/dev/null \
      | python3 -c 'import json,sys; print(json.load(sys.stdin)["casks"][0]["version"])' 2>/dev/null || true)"

    if [[ -n "$installed" && -n "$latest" && "$installed" == "$latest" ]]; then
      log "codex already up to date: ${installed}"
      return 0
    fi

    log "Updating codex (Homebrew cask): ${installed:-?} -> ${latest:-?}"
    brew upgrade --cask codex
    return 0
  fi

  install_codex_from_github
}

install_rtk() {
  ensure_cmd curl curl
  ensure_cmd tar tar

  # Pinned — upstream install.sh always grabs latest; to pin the binary we
  # fetch the release tarball directly. Bump manually.
  local rtk_version="0.37.1"

  local rtk_asset
  case "${os_name}/${arch_name}" in
    Darwin/arm64 | Darwin/aarch64) rtk_asset="rtk-aarch64-apple-darwin.tar.gz" ;;
    Darwin/x86_64 | Darwin/amd64)  rtk_asset="rtk-x86_64-apple-darwin.tar.gz" ;;
    Linux/x86_64  | Linux/amd64)   rtk_asset="rtk-x86_64-unknown-linux-musl.tar.gz" ;;
    Linux/arm64   | Linux/aarch64) rtk_asset="rtk-aarch64-unknown-linux-gnu.tar.gz" ;;
    *) echo "Unsupported platform for rtk: ${os_name} ${arch_name}" >&2; return 1 ;;
  esac

  local install_dir="${HOME}/.local/bin"
  mkdir -p "${install_dir}"

  local installed_version=""
  if [[ -x "${install_dir}/rtk" ]]; then
    installed_version="$("${install_dir}/rtk" --version 2>/dev/null | grep -Eo '[0-9]+\.[0-9]+\.[0-9]+' | head -n 1 || true)"
  fi

  if [[ "${installed_version}" == "${rtk_version}" ]]; then
    local latest
    latest="$(curl -fsSL "https://api.github.com/repos/rtk-ai/rtk/releases/latest" 2>/dev/null \
      | grep -m1 '"tag_name"' | grep -Eo '[0-9]+\.[0-9]+\.[0-9]+' | head -n 1 || true)"
    if [[ -n "${latest}" && "${latest}" != "${rtk_version}" ]]; then
      log "rtk ${rtk_version} installed (pinned; upstream ${latest} available — bump rtk_version in runs/ai)"
    elif [[ -n "${latest}" ]]; then
      log "rtk ${rtk_version} installed (pinned, up to date with upstream)"
    else
      log "rtk ${rtk_version} installed (pinned; upstream version check skipped)"
    fi
    return 0
  fi

  if [[ -n "${installed_version}" ]]; then
    log "Updating rtk: ${installed_version} -> ${rtk_version}"
  else
    log "Installing rtk ${rtk_version}"
  fi

  local tmpdir
  tmpdir="$(mktemp -d)"
  local url="https://github.com/rtk-ai/rtk/releases/download/v${rtk_version}/${rtk_asset}"

  curl -fsSL "${url}" -o "${tmpdir}/${rtk_asset}"
  tar -xzf "${tmpdir}/${rtk_asset}" -C "${tmpdir}"

  local extracted
  extracted="$(find "${tmpdir}" -type f -name rtk -perm -u=x | head -n 1)"
  if [[ -z "${extracted}" ]]; then
    rm -rf "${tmpdir}"
    echo "rtk binary not found after extracting ${rtk_asset}" >&2
    return 1
  fi

  install -m 0755 "${extracted}" "${install_dir}/rtk"
  rm -rf "${tmpdir}"

  if ! "${install_dir}/rtk" gain >/dev/null 2>&1; then
    echo "rtk installation verification failed: rtk gain did not succeed" >&2
    return 1
  fi

  log "Installed rtk ${rtk_version}"
}

install_uv() {
  # Always use the standard installer (not Homebrew) so that both uv and uvx
  # land in ~/.local/bin/ — the canonical cross-platform location used by MCP
  # configs. Homebrew puts them in /opt/homebrew/bin/ which GUI apps and MCP
  # server spawners can't find.
  if [[ -x "${HOME}/.local/bin/uvx" ]]; then
    log "uv already installed: $("${HOME}/.local/bin/uv" --version 2>/dev/null || echo ok)"
    return 0
  fi

  log "Installing uv (standard installer -> ~/.local/bin/)"
  curl -LsSf https://astral.sh/uv/install.sh | env UV_NO_MODIFY_PATH=1 sh

  if [[ -x "${HOME}/.local/bin/uvx" ]]; then
    log "Installed uv: $("${HOME}/.local/bin/uv" --version 2>/dev/null || echo ok)"
    return 0
  fi

  echo "uv install failed: ${HOME}/.local/bin/uvx not found" >&2
  return 1
}

install_claude_code() {
  if have claude; then
    log "claude already installed: $(claude --version 2>/dev/null | head -n 1 || echo ok)"
    return 0
  fi

  log "Installing Claude Code"
  curl -fsSL https://claude.ai/install.sh | bash

  if have claude; then
    log "Installed claude: $(claude --version 2>/dev/null | head -n 1 || echo ok)"
    return 0
  fi

  echo "Claude Code installation failed" >&2
  return 1
}

configure_claude_mcp() {
  local claude_json="${HOME}/.config/claude/.claude.json"
  if [[ ! -f "${claude_json}" ]]; then
    log "Skipping MCP setup: ${claude_json} not found (run claude once first)"
    return 0
  fi

  python3 - "${claude_json}" <<'PY'
import json, pathlib, sys
p = pathlib.Path(sys.argv[1])
d = json.loads(p.read_text())
desired = {
    '_managed_by': 'dev-env/runs/ai — do not edit, will be overridden',
    'type': 'stdio',
    'command': 'uvx',
    'args': ['--from', 'git+https://github.com/michaelschleiss/paper-search-mcp', 'paper-search-mcp'],
    'env': {'PATH': '${HOME}/.local/bin:${PATH}'},
}
servers = d.get('mcpServers', {})
if servers.get('paper-search') == desired:
    sys.exit(0)
servers['paper-search'] = desired
d['mcpServers'] = servers
p.write_text(json.dumps(d, indent=2) + '\n')
print('[ai] Configured paper-search MCP server')
PY
}

install_claude_browse() {
  local repo="https://github.com/michaelschleiss/claude-browse.git"
  local clone_dir="${HOME}/projects/claude-browse"
  local install_dir="${HOME}/.local/bin"
  local bin="${install_dir}/claude-browse"

  mkdir -p "${install_dir}"

  if [[ -d "${clone_dir}" ]]; then
    local before after
    before="$(git -C "${clone_dir}" rev-parse HEAD 2>/dev/null || echo '')"
    git -C "${clone_dir}" pull --ff-only --quiet 2>/dev/null || true
    after="$(git -C "${clone_dir}" rev-parse HEAD 2>/dev/null || echo '')"
    if [[ -n "$before" && "$before" != "$after" ]]; then
      log "Updated claude-browse: ${before:0:7} -> ${after:0:7}"
    else
      log "claude-browse up to date (${after:0:7})"
    fi
  else
    log "Installing claude-browse"
    git clone "${repo}" "${clone_dir}"
  fi

  local target="${clone_dir}/claude-browse"
  if [[ -L "${bin}" && "$(readlink "${bin}")" == "${target}" ]]; then
    :
  elif [[ -L "${bin}" || ! -e "${bin}" ]]; then
    ln -sf "${target}" "${bin}"
    log "Linked claude-browse -> ${bin}"
  fi
}

main() {
  install_uv
  install_rtk
  install_codex
  install_claude_code
  install_claude_browse
  configure_claude_mcp

  # Shell integration
  add_block_to_file "$HOME/.zprofile" "ai-env" 'export CLAUDE_CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/claude"
export CODEX_HOME="${XDG_CONFIG_HOME:-$HOME/.config}/codex"
export SERENA_HOME="${XDG_CONFIG_HOME:-$HOME/.config}/serena"'

  add_block_to_file "$HOME/.zshrc" "codex-completion" 'if [[ -o interactive ]] && command -v codex >/dev/null 2>&1; then
  if ! whence -w compdef >/dev/null 2>&1; then
    autoload -Uz compinit
    compinit -i
  fi
  if whence -w compdef >/dev/null 2>&1; then
    eval "$(codex completion zsh)"
  fi
fi'

  add_block_to_file "$HOME/.zshrc" "ai-aliases" 'alias cc="claude --allow-dangerously-skip-permissions"'

  log "Done"
}

main "$@"
