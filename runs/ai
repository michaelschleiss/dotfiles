#!/usr/bin/env bash
set -euo pipefail
LOG_PREFIX="[ai]"
source "$(dirname "$0")/_lib"

export PATH="${HOME}/.local/bin:${PATH}"

codex_target() {
  case "${os_name}/${arch_name}" in
    Darwin/arm64 | Darwin/aarch64) echo "aarch64-apple-darwin" ;;
    Darwin/x86_64 | Darwin/amd64) echo "x86_64-apple-darwin" ;;
    Linux/x86_64 | Linux/amd64) echo "x86_64-unknown-linux-musl" ;;
    Linux/arm64 | Linux/aarch64) echo "aarch64-unknown-linux-musl" ;;
    *) return 1 ;;
  esac
}

install_codex_from_github() {
  local target
  target="$(codex_target)" || {
    echo "Unsupported platform for codex: ${os_name} ${arch_name}" >&2
    return 1
  }

  ensure_cmd curl curl
  ensure_cmd tar tar

  # Tarball contains `codex-${target}`; helper matches it via bin_name-* glob
  # and installs as `codex`.
  install_pinned_github_release codex openai/codex latest "codex-${target}.tar.gz"
}

install_codex() {
  ensure_cmd rg ripgrep

  if [[ "$os_name" == "Darwin" ]] && have brew; then
    export HOMEBREW_NO_AUTO_UPDATE=1
    export HOMEBREW_NO_ENV_HINTS=1

    if ! brew list --cask codex >/dev/null 2>&1; then
      log "Installing codex (Homebrew cask)"
      brew install --cask codex
      return 0
    fi

    local installed latest
    installed="$(brew list --cask --versions codex 2>/dev/null | awk '{print $2}')"
    latest="$(brew info --cask --json=v2 codex 2>/dev/null \
      | python3 -c 'import json,sys; print(json.load(sys.stdin)["casks"][0]["version"])' 2>/dev/null || true)"

    if [[ -n "$installed" && -n "$latest" && "$installed" == "$latest" ]]; then
      log "codex already up to date: ${installed}"
      return 0
    fi

    log "Updating codex (Homebrew cask): ${installed:-?} -> ${latest:-?}"
    brew upgrade --cask codex
    return 0
  fi

  install_codex_from_github
}

install_rtk() {
  ensure_cmd curl curl
  ensure_cmd tar tar

  # Pinned — upstream install.sh always grabs latest; pin the binary instead.
  # Bump manually.
  local rtk_version="0.37.1"

  local asset
  case "${os_name}/${arch_name}" in
    Darwin/arm64 | Darwin/aarch64) asset="rtk-aarch64-apple-darwin.tar.gz" ;;
    Darwin/x86_64 | Darwin/amd64)  asset="rtk-x86_64-apple-darwin.tar.gz" ;;
    Linux/x86_64  | Linux/amd64)   asset="rtk-x86_64-unknown-linux-musl.tar.gz" ;;
    Linux/arm64   | Linux/aarch64) asset="rtk-aarch64-unknown-linux-gnu.tar.gz" ;;
    *) echo "Unsupported platform for rtk: ${os_name} ${arch_name}" >&2; return 1 ;;
  esac

  install_pinned_github_release rtk rtk-ai/rtk "$rtk_version" "$asset"

  if ! "${HOME}/.local/bin/rtk" gain >/dev/null 2>&1; then
    echo "rtk installation verification failed: rtk gain did not succeed" >&2
    return 1
  fi

  # Advisory: flag if upstream has moved past our pin.
  local latest
  latest="$(curl -fsSL "https://api.github.com/repos/rtk-ai/rtk/releases/latest" 2>/dev/null \
    | grep -m1 '"tag_name"' | grep -Eo '[0-9]+\.[0-9]+\.[0-9]+' | head -n 1 || true)"
  if [[ -n "${latest}" && "${latest}" != "${rtk_version}" ]]; then
    log "rtk pinned at ${rtk_version}; upstream ${latest} available — bump rtk_version in runs/ai"
  fi
}

install_uv() {
  # Always use the standard installer (not Homebrew) so that both uv and uvx
  # land in ~/.local/bin/ — the canonical cross-platform location used by MCP
  # configs. Homebrew puts them in /opt/homebrew/bin/ which GUI apps and MCP
  # server spawners can't find.
  if [[ -x "${HOME}/.local/bin/uvx" ]]; then
    log "uv already installed: $("${HOME}/.local/bin/uv" --version 2>/dev/null || echo ok)"
    return 0
  fi

  log "Installing uv (standard installer -> ~/.local/bin/)"
  curl -LsSf https://astral.sh/uv/install.sh | env UV_NO_MODIFY_PATH=1 sh

  if [[ -x "${HOME}/.local/bin/uvx" ]]; then
    log "Installed uv: $("${HOME}/.local/bin/uv" --version 2>/dev/null || echo ok)"
    return 0
  fi

  echo "uv install failed: ${HOME}/.local/bin/uvx not found" >&2
  return 1
}

install_claude_code() {
  if have claude; then
    log "claude already installed: $(claude --version 2>/dev/null | head -n 1 || echo ok)"
    return 0
  fi

  log "Installing Claude Code"
  curl -fsSL https://claude.ai/install.sh | bash

  if have claude; then
    log "Installed claude: $(claude --version 2>/dev/null | head -n 1 || echo ok)"
    return 0
  fi

  echo "Claude Code installation failed" >&2
  return 1
}

configure_claude_mcp() {
  local claude_json="${HOME}/.config/claude/.claude.json"
  if [[ ! -f "${claude_json}" ]]; then
    log "Skipping MCP setup: ${claude_json} not found (run claude once first)"
    return 0
  fi

  python3 - "${claude_json}" <<'PY'
import json, pathlib, sys
p = pathlib.Path(sys.argv[1])
d = json.loads(p.read_text())
desired = {
    '_managed_by': 'dev-env/runs/ai — do not edit, will be overridden',
    'type': 'stdio',
    'command': 'uvx',
    'args': ['--from', 'git+https://github.com/michaelschleiss/paper-search-mcp', 'paper-search-mcp'],
    'env': {'PATH': '${HOME}/.local/bin:${PATH}'},
}
servers = d.get('mcpServers', {})
if servers.get('paper-search') == desired:
    sys.exit(0)
servers['paper-search'] = desired
d['mcpServers'] = servers
p.write_text(json.dumps(d, indent=2) + '\n')
print('[ai] Configured paper-search MCP server')
PY
}

install_claude_browse() {
  local repo="https://github.com/michaelschleiss/claude-browse.git"
  local clone_dir="${HOME}/projects/claude-browse"
  local install_dir="${HOME}/.local/bin"
  local bin="${install_dir}/claude-browse"

  mkdir -p "${install_dir}"

  if [[ -d "${clone_dir}" ]]; then
    local before after
    before="$(git -C "${clone_dir}" rev-parse HEAD 2>/dev/null || echo '')"
    git -C "${clone_dir}" pull --ff-only --quiet 2>/dev/null || true
    after="$(git -C "${clone_dir}" rev-parse HEAD 2>/dev/null || echo '')"
    if [[ -n "$before" && "$before" != "$after" ]]; then
      log "Updated claude-browse: ${before:0:7} -> ${after:0:7}"
    else
      log "claude-browse up to date (${after:0:7})"
    fi
  else
    log "Installing claude-browse"
    git clone "${repo}" "${clone_dir}"
  fi

  local target="${clone_dir}/claude-browse"
  if [[ -L "${bin}" && "$(readlink "${bin}")" == "${target}" ]]; then
    :
  elif [[ -L "${bin}" || ! -e "${bin}" ]]; then
    ln -sf "${target}" "${bin}"
    log "Linked claude-browse -> ${bin}"
  fi
}

main() {
  install_uv
  install_rtk
  install_codex
  install_claude_code
  install_claude_browse
  configure_claude_mcp

  # Shell integration
  add_block_to_file "$HOME/.zprofile" "ai-env" 'export CLAUDE_CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/claude"
export CODEX_HOME="${XDG_CONFIG_HOME:-$HOME/.config}/codex"
export SERENA_HOME="${XDG_CONFIG_HOME:-$HOME/.config}/serena"'

  add_block_to_file "$HOME/.zshrc" "codex-completion" 'if [[ -o interactive ]] && command -v codex >/dev/null 2>&1; then
  if ! whence -w compdef >/dev/null 2>&1; then
    autoload -Uz compinit
    compinit -i
  fi
  if whence -w compdef >/dev/null 2>&1; then
    eval "$(codex completion zsh)"
  fi
fi'

  add_block_to_file "$HOME/.zshrc" "ai-aliases" 'alias cc="claude --allow-dangerously-skip-permissions"'

  log "Done"
}

main "$@"
